//------------------------MENU IMGUI-------------------------------

void BeginDraw() {
        

        ImGuiIO & io = ImGui::GetIO();
		
		DrawESP(ImGui::GetBackgroundDrawList(), ScreenWidht, ScreenHeight);
		
		
        const ImGuiViewport* main_viewport = ImGui::GetMainViewport();
    ImGui::SetNextWindowPos(ImVec2(main_viewport->WorkPos.x + 100, main_viewport->WorkPos.y + 220), ImGuiCond_FirstUseEver);
  //  ImGui::SetNextWindowPos(ImVec2(main_viewport->WorkPos.x + 250, main_viewport->WorkPos.y + 20), ImGuiCond_FirstUseEver);
    ImGui::SetNextWindowSize(ImVec2(500, 350), ImGuiCond_FirstUseEver);

    char buf[128];
    sprintf(buf, "  ImGui Unity | @TokyoModder");

    if (ImGui::Begin(buf, 0, ImGuiWindowFlags_NoScrollbar | ImGuiWindowFlags_NoScrollWithMouse)) {
        g_window = ImGui::GetCurrentWindow();

        if (ImGui::Button("ESP", ImVec2(140, 50))) Hell = 1;
        ImGui::SameLine();
        if (ImGui::Button("AIM", ImVec2(140, 50))) Hell = 2;
        ImGui::SameLine();
        if (ImGui::Button("WEAPON", ImVec2(140, 50))) Hell = 3;
        

        if (Hell == 1) {
            ImGui::Spacing();
            ImGui::PushStyleColor(ImGuiCol_Text, IM_COL32(0, 255, 0, 255));
            ImGui::Text(" TokyoModz          FPS : %.2f", io.Framerate);
       //     ImGui::TextColored(ImVec4(0.0f, 1.0f, 0.0f, 1.0f), "SetCurrency raw address: 0x%lx", getAddr::purchase);
            ImGui::PopStyleColor();

            ImGui::Separator();

            if (ImGui::BeginTable("split", 3)) {
                ImGui::TableNextColumn();
                ImGui::Checkbox("ESP", &Esp);
                ImGui::TableNextColumn();
                ImGui::Checkbox("Line", &ESPLine);
                ImGui::TableNextColumn();
                ImGui::Checkbox("Box", &ESPBox);
                
                
                
        //       ImGui::Checkbox("Enable Infinite Currency", &var.InfiniteCurrency);

                
                
                
                
                ImGui::EndTable();
            }

            ImGui::Separator();
            ImGui::Text(" STATUS -");
            ImGui::SameLine();
            ImGui::PushStyleColor(ImGuiCol_Text, IM_COL32(255, 0, 0, 255));
            ImGui::Text(" SAFE (PLAY SAFE)");
            ImGui::PopStyleColor();
        }

        if (Hell == 2) {
        
        	ImGui::Spacing();
            ImGui::PushStyleColor(ImGuiCol_Text, IM_COL32(0, 255, 0, 255));
            ImGui::Text(" TokyoModz          FPS : %.2f", io.Framerate);
       //     ImGui::TextColored(ImVec4(0.0f, 1.0f, 0.0f, 1.0f), "SetCurrency raw address: 0x%lx", getAddr::purchase);
            ImGui::PopStyleColor();

            ImGui::Separator();

            if (ImGui::BeginTable("split", 3)) {
                ImGui::TableNextColumn();
                ImGui::Checkbox("Aimbot 2.0", &Esp);
            /*    ImGui::TableNextColumn();
                ImGui::Checkbox("Line", &ESPLine);
                ImGui::TableNextColumn();
                ImGui::Checkbox("Box", &ESPBox);
                */
                
                
        //       ImGui::Checkbox("Enable Infinite Currency", &var.InfiniteCurrency);

                
                
                
                
                ImGui::EndTable();
                }
        
            
            
        }
        if (Hell == 3) {
			ImGui::Spacing();
            ImGui::PushStyleColor(ImGuiCol_Text, IM_COL32(0, 255, 0, 255));
            ImGui::Text(" TokyoModz          FPS : %.2f", io.Framerate);
       //     ImGui::TextColored(ImVec4(0.0f, 1.0f, 0.0f, 1.0f), "SetCurrency raw address: 0x%lx", getAddr::purchase);
            ImGui::PopStyleColor();

            ImGui::Separator();

            if (ImGui::BeginTable("split", 3)) {
                ImGui::TableNextColumn();
                ImGui::Checkbox("Max Ammo", &bulletsLeft);
                ImGui::TableNextColumn();
                ImGui::Checkbox("Fire Rate", &fireRate);
                ImGui::TableNextColumn();
                ImGui::Checkbox("One Hit", &ESPBox);
                
                
                
        //       ImGui::Checkbox("Enable Infinite Currency", &var.InfiniteCurrency);

                
                
                
                
                ImGui::EndTable();
                }
   			} 				 
        ImGui::End();
      }
  }

