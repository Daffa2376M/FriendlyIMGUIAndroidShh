bool drawBehindMenu = true;

ImDrawList* getDrawList(){
    ImDrawList *drawList;
    if(drawBehindMenu){
        drawList = ImGui::GetBackgroundDrawList();
    } else {
        drawList = ImGui::GetForegroundDrawList();
    }
    return drawList;
}


